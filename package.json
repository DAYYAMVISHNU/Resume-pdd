{
  "name": "resume-analyzer-root",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "backend": "cd backend && ..\\.venv\\Scripts\\python.exe app.py",
    "start": "concurrently \"npm run dev --prefix frontend\" \"npm run backend\"",
    "build": "npm run build --prefix frontend",
    "sync-android": "npm run sync-android --prefix frontend",
    "flutter-run": "cd mobile_flutter && flutter run",
    "open-android": "npm run open-android --prefix frontend",
    "lint": "npm run lint --prefix frontend",
    "preview": "npm run preview --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
