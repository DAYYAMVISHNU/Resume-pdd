{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/analyze", "destination": "/api/index" },
    { "source": "/ats_check", "destination": "/api/index" },
    { "source": "/analytics", "destination": "/api/index" },
    { "source": "/ping", "destination": "/api/index" },
    { "source": "/active_users", "destination": "/api/index" },
    { "source": "/share", "destination": "/api/index" },
    { "source": "/chat/:path*", "destination": "/api/index" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
